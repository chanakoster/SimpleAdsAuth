@using SimpleAdsAuth.Data
@model AdsViewModel

<div b-gyvb0mk0dj class="container" style="margin-top:80px;">
    <main b-gyvb0mk0dj role="main" class="pb-3">

        <div class="row">
            <div class="col-md-6 offset-md-3">
                @foreach (var ad in Model.Ads)
                {
                    <div class="bg-light p-4 rounded shadow mb-3">
                        <h5>Listed by @ad.User.Name</h5>
                        <h5>Listed on @ad.Date.ToString("dddd, dd MMMM yyyy")</h5>
                        <h5>Phone Number: @ad.PhoneNumber</h5>
                        <h3>Details:</h3>
                        <p>@ad.Description</p>
                        @if (ad.Id == Model.AdId)
                        {
                            <span class="text-danger">@ViewBag.Message</span>
                        }
                        @if (Model.UserId == ad.User.Id)
                        {
                            <form method="post" action="/home/deletead">
                                <input type="hidden" name="id" value="@ad.Id" />
                                <button class="btn btn-danger">Delete</button>
                            </form>
                        }
                    </div>
                }

            </div>
        </div>
    </main>
</div>